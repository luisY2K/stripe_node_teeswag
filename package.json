{
  "name": "teeswag-alt",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "setup:awesome": "tsx --env-file=.env src/scripts/setupAwesome.ts",
    "setup:subscription": "tsx --env-file=.env src/scripts/setupSubscription.ts",
    "dev": "tsx --env-file=.env src/scripts/example.ts",
    "script": "tsx --env-file=.env",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration --env-file=.env",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project unit --coverage"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
